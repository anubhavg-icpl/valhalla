<?xml version='1.0' encoding='windows-1252'?>
<!--
  Valhalla MSI installer definition (WiX Toolset v3).

  Build:
    candle -ext WixUIExtension valhalla.wxs -out valhalla.wixobj
    light  -ext WixUIExtension valhalla.wixobj -out valhalla-0.1.0-x64.msi

  Or via xtask:
    cargo xtask msi
-->
<Wix xmlns='http://schemas.microsoft.com/wix/2006/wi'>
  <Product
    Name='Valhalla'
    Id='*'
    UpgradeCode='$(var.UpgradeCode)'
    Language='1033'
    Codepage='1252'
    Version='0.1.0'
    Manufacturer='Valhalla Project'>

    <Package Id='*'
      Keywords='Installer,Valhalla'
      Description='Valhalla 0.1.0 Installer'
      Comments='Valhalla is a Rust-native Windows kernel monitoring driver and companion user-mode client.'
      Manufacturer='Valhalla Project'
      InstallerVersion='500'
      Languages='1033'
      Compressed='yes'
      SummaryCodepage='1252'
      Platform='x64' />

    <!-- Major upgrade support: uninstall older versions automatically. -->
    <MajorUpgrade
      DowngradeErrorMessage='A newer version of Valhalla is already installed.' />

    <Media Id='1' Cabinet='valhalla.cab' EmbedCab='yes' />

    <!-- Disable modify/repair in ARP; only allow uninstall. -->
    <Property Id='ARPNOMODIFY' Value='1' Secure='yes' />
    <Property Id='ARPNOREPAIR' Value='1' Secure='yes' />
    <Property Id='ARPHELPLINK' Value='https://github.com/anubhavg-icpl/valhalla' />
    <Property Id='ARPURLINFOABOUT' Value='https://github.com/anubhavg-icpl/valhalla' />

    <!-- Install for all users (machine-wide). -->
    <Property Id='ALLUSERS' Value='1' />

    <!-- Icon shown in Add/Remove Programs. -->
    <Icon Id='valhalla.ico' SourceFile='installer\assets\logo.ico' />
    <Property Id='ARPPRODUCTICON' Value='valhalla.ico' />

    <!-- Feature tree. -->
    <Feature Id='Complete' Title='Valhalla' Description='Complete installation' Level='1' Display='expand' ConfigurableDirectory='INSTALLDIR'>
      <Feature Id='ClientFeature' Title='Valhalla Client' Description='User-mode event reader' Level='1'>
        <ComponentRef Id='ClientFiles' />
        <ComponentRef Id='ClientShortcut' />
      </Feature>
      <Feature Id='DriverFeature' Title='Valhalla Driver' Description='Kernel-mode monitoring driver' Level='1'>
        <ComponentRef Id='DriverFiles' />
      </Feature>
    </Feature>

    <!-- Standard UI with Valhalla branding. -->
    <UIRef Id='WixUI_FeatureTree' />
    <WixVariable Id='WixUILicenseRtf' Value='installer\license.rtf' />
    <WixVariable Id='WixUIDialogBmp' Value='installer\assets\dialog.bmp' />
    <WixVariable Id='WixUIBannerBmp' Value='installer\assets\banner.bmp' />
    <WixVariable Id='WixUIExclamationIco' Value='installer\assets\logo.ico' />
    <WixVariable Id='WixUIInfoIco' Value='installer\assets\logo.ico' />
    <WixVariable Id='WixUINewIco' Value='installer\assets\logo.ico' />
    <WixVariable Id='WixUIUpIco' Value='installer\assets\logo.ico' />

    <!-- Custom text for the UI dialogs. -->
    <Property Id='WIXUI_EXITDIALOGOPTIONALTEXT' Value='Thank you for installing Valhalla. The user-mode client is available in your Start Menu under "Valhalla Client".' />
    <Property Id='WIXUI_EXITDIALOGOPTIONALCHECKBOXTEXT' Value='Launch Valhalla Client now' />

    <!-- Directory layout: C:\Program Files\Valhalla -->
    <Directory Id='TARGETDIR' Name='SourceDir'>
      <Directory Id='ProgramFiles64Folder' Name='PFiles64'>
        <Directory Id='INSTALLDIR' Name='Valhalla'>
          <!-- Client component -->
          <Component Id='ClientFiles' Guid='$(var.ClientComponentGuid)' Win64='yes'>
            <File Id='ValhallaClientExe' Name='valhalla-client.exe' DiskId='1' Source='$(var.ClientExePath)' KeyPath='yes' />
          </Component>
          <!-- Driver component (optional) -->
          <Component Id='DriverFiles' Guid='$(var.DriverComponentGuid)' Win64='yes'>
            <File Id='ValhallaSys' Name='valhalla.sys' DiskId='1' Source='$(var.DriverPath)' KeyPath='yes' />
          </Component>
        </Directory>
      </Directory>
      <!-- Start Menu shortcuts -->
      <Directory Id='ProgramMenuFolder' Name='Programs'>
        <Directory Id='ProgramMenuDir' Name='Valhalla'>
          <Component Id='ClientShortcut' Guid='$(var.ShortcutComponentGuid)' Win64='yes'>
            <RemoveFolder Id='ProgramMenuDir' On='uninstall' />
            <RegistryValue Root='HKCU' Key='Software\Valhalla Project\Valhalla' Name='Installed' Type='integer' Value='1' KeyPath='yes' />
            <Shortcut Id='ValhallaClientShortcut'
              Name='Valhalla Client'
              Description='Run the Valhalla user-mode client'
              Target='[INSTALLDIR]valhalla-client.exe'
              WorkingDirectory='INSTALLDIR' />
          </Component>
        </Directory>
      </Directory>
    </Directory>

  </Product>
</Wix>
